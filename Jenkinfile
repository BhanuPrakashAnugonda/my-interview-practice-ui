pipeline {
  agent any

  environment {
    IMAGE_NAME = "my-nextjs-app"
    CONTAINER_NAME = "nextjs-container"
  }

  stages {

    stage('Checkout') {
      steps {
        git 'https://github.com/BhanuPrakashAnugonda/my-interview-practice-ui.git'
      }
    }

    stage('Install & Build (Node 20)') {
 
      steps {
        sh '''
        node -v
        npm install
        npm run build
        '''
      }
    }

    stage('Docker Build') {
      steps {
        sh 'docker build -t $IMAGE_NAME .'
      }
    }

    stage('Run Container') {
      steps {
        sh '''
        docker rm -f $CONTAINER_NAME || true
        docker run -d -p 80:3000 --name $CONTAINER_NAME $IMAGE_NAME
        '''
      }
    }

  }

  post {
    success {
      echo "✅ App deployed successfully!"
      echo "🌐 Access: http://localhost:3000"
    }
    failure {
      echo "❌ Pipeline failed. Check logs."
    }
  }
}
